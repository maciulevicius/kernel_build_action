name: Build OnePlus 8T HA-Server Kernel NEW

on:
  workflow_dispatch:

jobs:
  build-kernel:
    runs-on: ubuntu-22.04
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y bc bison build-essential cpio flex git libelf-dev libssl-dev make python3 xz-utils curl

      - name: Clone Proton Clang
        run: |
          git clone --depth 1 https://github.com/kdrag0n/proton-clang clang
          echo "$GITHUB_WORKSPACE/clang/bin" >> $GITHUB_PATH

      - name: Clone Kernel Source
        run: |
          # crDroid 14.0 šaltinis (pats stabiliausias OnePlus 8T)
          git clone --depth 1 -b 14.0 https://github.com/crdroidandroid/android_kernel_oneplus_sm8250 kernel

      - name: Patch Kernel
        run: |
          cd kernel
          # 1. Sutvarkome blykstės klaidą
          cat <<EOF > drivers/power/supply/qcom/schgm-flash.c
          #include <linux/types.h>
          #include <linux/export.h>
          #include <linux/kernel.h>
          bool is_flash_active(void) { return false; }
          EXPORT_SYMBOL(is_flash_active);
          int schgm_flash_torch_priority(int level) { return 0; }
          EXPORT_SYMBOL(schgm_flash_torch_priority);
          int schgm_flash_init(void *data) { return 0; }
          EXPORT_SYMBOL(schgm_flash_init);
          bool schgm_flash_get_vreg_ok(void) { return true; }
          EXPORT_SYMBOL(schgm_flash_get_vreg_ok);
          int schgm_flash_ilim2_irq_handler(int irq, void *data) { return 0; }
          EXPORT_SYMBOL(schgm_flash_ilim2_irq_handler);
          int schgm_flash_state_change_irq_handler(int irq, void *data) { return 0; }
          EXPORT_SYMBOL(schgm_flash_state_change_irq_handler);
          EOF
          
          # 2. Konfigūracija
          DEFCONFIG="arch/arm64/configs/vendor/kona-perf_defconfig"
          sed -i 's/CONFIG_WERROR=y/CONFIG_WERROR=n/g' $DEFCONFIG
          
          {
            echo "CONFIG_WERROR=n"
            echo "CONFIG_SECTION_MISMATCH_WARN_ONLY=y"
            # Docker bazė
            echo "CONFIG_OVERLAY_FS=y"
            echo "CONFIG_CGROUP_BPF=y"
            echo "CONFIG_MEMCG_SWAP=y"
            echo "CONFIG_MEMCG_SWAP_ENABLED=y"
            # USB Serial Zigbee lazdelėms (Visi čipai: CP2102, CH341, FTDI, PL2303)
            echo "CONFIG_USB_SERIAL=y"
            echo "CONFIG_USB_SERIAL_GENERIC=y"
            echo "CONFIG_USB_SERIAL_CP210X=y"
            echo "CONFIG_USB_SERIAL_FTDI_SIO=y"
            echo "CONFIG_USB_SERIAL_CH341=y"
            echo "CONFIG_USB_SERIAL_PL2303=y"
            echo "CONFIG_USB_SERIAL_OPTION=y"
            # USB Storage HA diskams
            echo "CONFIG_USB_STORAGE=y"
            echo "CONFIG_USB_UAS=y"
            echo "CONFIG_EXFAT_FS=y"
            echo "CONFIG_NTFS_FS=y"
            echo "CONFIG_OPLUS_CHG=y"
          } >> $DEFCONFIG

      - name: Build Kernel
        run: |
          cd kernel
          export PATH=$GITHUB_WORKSPACE/clang/bin:$PATH
          make O=out ARCH=arm64 vendor/kona-perf_defconfig
          make O=out ARCH=arm64 olddefconfig
          # Buildiname branduolį ir įrenginio medžius (dtbs)
          make -j2 O=out ARCH=arm64 \
            CC=clang \
            CROSS_COMPILE=aarch64-linux-gnu- \
            CROSS_COMPILE_ARM32=arm-linux-gnueabi- \
            LLVM=1 \
            LLVM_IAS=1 \
            KCFLAGS="-w -Wno-error" \
            KCPPFLAGS="-D__ANDROID_COMMON_KERNEL__" \
            Image.gz dtbs

      - name: Collect Artifacts
        run: |
          # Sukuriame vieną aplanką visiems failams surinkti
          mkdir -p HA_Server_Kernel
          # Branduolys
          cp kernel/out/arch/arm64/boot/Image.gz HA_Server_Kernel/
          # Surandame visus sugeneruotus DTB ir DTBO failus
          find kernel/out/arch/arm64/boot/dts/ -name "*.dtb" -exec cp {} HA_Server_Kernel/ \;
          find kernel/out/arch/arm64/boot/dts/ -name "*.dtbo" -exec cp {} HA_Server_Kernel/ \;
          echo "Surinkti failai:"
          ls -lh HA_Server_Kernel/

      - name: Upload HA Server Package
        uses: actions/upload-artifact@v4
        with:
          name: OnePlus8T-HA-Docker-Package
          path: HA_Server_Kernel/*